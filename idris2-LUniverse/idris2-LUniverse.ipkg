package idris2-LUniverse
version = 0.1.0
authors = "Justin"

depends = base, contrib, idris2-chromogeometry, idris2-Maxel, idris2-Multiset-Advanced, idris2-RationalTopology, linear, ref1, idris2-Universe, idris2-QuickCheck

sourcedir = "src"

modules = LMath.Core, LMath.Twist, LMath.DiscreteCalculus, LPhysics.Particles.Photon, LPhysics.Particles.Quark, LPhysics.Particles.Baryon, LPhysics.Particles.Meson, LPhysics.Particles.Electron, LPhysics.Particles.WeakBoson, LPhysics.Particles.Bond, LPhysics.Particles.Neutrino, LPhysics.Evolution.Gate, LPhysics.Evolution.LGate, LPhysics.WeakForce, LPhysics.Laws.ColorConfinement, LPhysics.Laws.EnergyConservation, LPhysics.Laws.PrimorialConservation, LPhysics.Laws.PauliExclusion, LPhysics.Evolution.Cycle, LPhysics.Evolution.Transform, LPhysics.Evolution.Clock, LPhysics.Evolution.State, LPhysics.Evolution.Init, LPhysics.Findings.Baryogenesis, LPhysics.Findings.Cosmology, LPhysics.Findings.HolographicFreeze, LPhysics.Findings.DarkEnergyExpansion, LPhysics.Findings.DarkMatterFriction, LPhysics.Findings.HadronGluonDynamics, LPhysics.Findings.CosmicPartition, LPhysics.Findings.CosmicEnergyBudget, LPhysics.Findings.PeriodicTable, LPhysics.Findings.GravitationalTimeDilation, LPhysics.Findings.TullyFisherRelation, LPhysics.Findings.StrongNuclearForce, LPhysics.Findings.VacuumPairProduction, LPhysics.Findings.FineStructureDerivation, LPhysics.Findings.CosmologicalConstant, LPhysics.Findings.MassRatios, LPhysics.Findings.Spread13, LPhysics.Evolution.Identity, LPhysics.Scales.Phylogeny, LPhysics.Scales.NaturalFolding, LPhysics.Scales.PythagoreanFixedPoint, LPhysics.Scales.IceGeometry, LPhysics.Scales.ScaleTrajectory, LPhysics.Elements.Hydrogen, LPhysics.Elements.Oxygen, LPhysics.Elements.Water, LPhysics.SpreadPolynumber, LPhysics.Bridge, LPhysics.Tests.Common, LPhysics.Tests.Bridge
